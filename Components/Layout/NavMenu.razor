</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" aria-label="Toggle navigation menu" />

<nav class="nav-scrollable" aria-label="Main navigation">
    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
    <NavLink class="nav-link" href="players">Players</NavLink>
    <NavLink class="nav-link" href="tournaments">Tournaments</NavLink>
    <NavLink class="nav-link" href="matches">Matches</NavLink>
