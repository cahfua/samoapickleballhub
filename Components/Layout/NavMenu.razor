    <AuthorizeView>
        <Authorized>
            <NavLink class="nav-link" href="Account/Manage">Account</NavLink>
            <form action="Account/Logout" method="post">
                <AntiforgeryToken />
                <button class="nav-link logout-button" type="submit">Logout</button>
            </form>
        </Authorized>
        <NotAuthorized>
            <NavLink class="nav-link" href="Account/Login">Login</NavLink>
